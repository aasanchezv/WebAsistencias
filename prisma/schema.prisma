generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id              Int      @id @default(autoincrement())
  name            String
  slug            String   @unique
  logo_url        String
  primary_color   String
  secondary_color String?
  createdAt       DateTime @default(now())
  active Boolean @default(true)

  users User[]
  services ClientService[]
}

model User {
  id       Int     @id @default(autoincrement())
  email    String
  password String
  name     String?
  clientId Int
  client   Client  @relation(fields: [clientId], references: [id])
  active Boolean @default(true)

  createdAt DateTime @default(now())

  @@unique([email, clientId])
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?

  createdAt DateTime @default(now())
}


model Service {
  id          Int      @id @default(autoincrement())
  name        String?
  icon        String
  text        String
  description String
  active Boolean @default(true)

  createdAt DateTime @default(now())

  subservices Subservice[]
  clients  ClientService[]
}

model Subservice {
  id          Int      @id @default(autoincrement())
  name        String?
  icon        String
  text        String
  description String
  serviceId   Int
  service     Service  @relation(fields: [serviceId], references: [id])

  phone     String?
  whatsapp  String?
  
  createdAt DateTime @default(now())
}

model ClientService {
  id        Int      @id @default(autoincrement())
  clientId  Int
  serviceId Int
  client    Client   @relation(fields: [clientId], references: [id])
  service   Service  @relation(fields: [serviceId], references: [id])
  createdAt DateTime @default(now())

  @@unique([clientId, serviceId])
}

model Page {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}